DATABASE_URL=sqlite:///./find_my_job.db
CORS_ORIGINS=http://localhost:3000

# 선택
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (OpenAI 키가 없을 때 사용). 모델명은 `ollama list`와 정확히 일치해야 함.
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3:latest
# OLLAMA_ENABLED=true
# SEED_DEMO_ON_EMPTY=true

# 컨설턴트 가져오기 시 LLM 필드 추출 (OpenAI 또는 Ollama)
# CONSULTANT_IMPORT_LLM=true
