# 프론트엔드 (Next.js)
# SSR/빌드 시 API 직접 호출용 (브라우저는 next.config rewrites 로 /api 프록시)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Next rewrites 대상 백엔드 (기본 127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000

# 백엔드 (FastAPI) — backend/.env 에 두거나 루트에서 공유
DATABASE_URL=sqlite:///./find_my_job.db
CORS_ORIGINS=http://localhost:3000

# 선택: OpenAI로 추천 문장 고도화
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# OpenAI 미설정 시 로컬 Llama (Ollama 권장). ollama pull llama3:latest 후 Ollama 실행
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3:latest

# 최초 DB가 비었을 때 데모 시드 적재 (실데이터만 쓰려면 false)
# SEED_DEMO_ON_EMPTY=true
